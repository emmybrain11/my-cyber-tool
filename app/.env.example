# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Frontend (exposed to browser via Vite) ──────────────────────
# No external demo auth provider is used. Configure local access below.
VITE_APP_NAME=            # Application name shown in the UI

# ── Backend ──────────────────────────────────────────────────────────
ADMIN_EMAIL=              # Local admin login email (required for initial access)
ADMIN_PASSWORD=           # Local admin login password
APP_SECRET=               # Application secret used for JWT signing
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)
ALLOW_SCRIPT_EXECUTION=1  # Set to 1 to enable script execution in the secured lab environment
PYTHON_SERVICE_URL=http://127.0.0.1:8000  # Local Python service endpoint for repo cloning and tool execution
OLLA_API_URL=             # Ollama HTTP endpoint (e.g. http://localhost:11434). Leave blank to use local Ollama CLI when available.
OLLA_MODEL=               # Ollama model name (e.g. llama2). Any installed model can be used.

# ── Deployment ──────────────────────────────────────────────────────
OWNER_EMAIL=              # Optional owner/admin email for role elevation
